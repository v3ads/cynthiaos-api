# ── Server ────────────────────────────────────────────────────────────────────
PORT=3003
SERVICE_NAME=cynthiaos-api
NODE_ENV=development

# ── Database (Neon Postgres — read from Gold schema only) ─────────────────────
DATABASE_URL=postgres://user:password@host/dbname?sslmode=require

# ── Authentication ────────────────────────────────────────────────────────────
JWT_SECRET=replace_with_real_secret
JWT_EXPIRES_IN=8h

# ── AI Copilot (Jasmine) ──────────────────────────────────────────────────────
JASMINE_API_URL=https://replace_with_jasmine_endpoint
JASMINE_API_KEY=replace_with_real_key

# ── App Layer CORS origin ─────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000
